# =============================================================
# Fluxo Digital Tech - Project Template
# .env.example
# -------------------------------------------------------------
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA faca commit do arquivo .env (ja esta no .gitignore).
# =============================================================

# ---- Aplicacao ----
NODE_ENV=development
PORT=3000
APP_NAME=meu-projeto
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ---- Banco de dados ----
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379

# ---- APIs / Integracoes (preencher localmente, nao commitar) ----
# OPENAI_API_KEY=
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
# WHATSAPP_TOKEN=
# INSTAGRAM_TOKEN=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---- Seguranca ----
# JWT_SECRET=
# SESSION_SECRET=

# ---- Webhooks ----
# WEBHOOK_URL=
# WEBHOOK_SECRET=
